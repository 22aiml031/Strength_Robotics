SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Or use SUPABASE_KEY=your-publishable-or-anon-key if your RLS policies allow reads/writes.

# Ollama defaults. Pull these models first, or change the names to models you have.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=all-minilm
OLLAMA_CHAT_MODEL=gemma3:4b

# Must match the vector dimension in sql/schema.sql.
EMBEDDING_DIM=384

# Retrieval/generation controls.
MATCH_COUNT=6
CHUNK_SIZE=380
CHUNK_OVERLAP=60
